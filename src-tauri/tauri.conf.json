{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Alyvo Edu",
  "mainBinaryName": "AlyvoEdu",
  "version": "0.0.0",
  "identifier": "fr.alyvo.edu",
  "build": {
    "frontendDist": "../src-nuxt/.output/public/",
    "devUrl": "http://localhost:1470",
    "beforeDevCommand": "tsx src-tauri/scripts/beforeDevCommand.ts",
    "beforeBuildCommand": "tsx src-tauri/scripts/beforeBuildCommand.ts"
  },
  "app": {
    "windows": [
      {
        "fullscreen": false,
        "width": 290,
        "height": 380,
        "resizable": false,
        "title": "Alyvo Edu",
        "decorations": false,
        "center": true,
        "alwaysOnTop": false,
        "visible": true,
        "url": "/",
        "label": "main"
      }
    ],
    "enableGTKAppId": false,
    "macOSPrivateApi": true,
    "security": {
      "csp": {
        "default-src": "'self' customprotocol: asset:",
        "connect-src": [
          "ipc:",
          "http://ipc.localhost",
          "http://localhost:3500",
          "https://staging.api.edu.alyvo.fr",
          "https://api.edu.alyvo.fr",
          "https://s3.gra.io.cloud.ovh.net",
          "https://*.s3.gra.io.cloud.ovh.net"
        ],
        "script-src": "'self'",
        "style-src": "'self' 'unsafe-inline'",
        "img-src": [
          "'self'",
          "asset:",
          "http://asset.localhost",
          "data:",
          "blob:",
          "http://localhost:3500",
          "https://staging.api.edu.alyvo.fr",
          "https://api.edu.alyvo.fr",
          "https://s3.gra.io.cloud.ovh.net",
          "https://*.s3.gra.io.cloud.ovh.net"
        ],
        "media-src": [
          "'self'",
          "asset:",
          "http://asset.localhost",
          "data:",
          "blob:",
          "http://localhost:3500",
          "https://staging.api.edu.alyvo.fr",
          "https://api.edu.alyvo.fr",
          "https://s3.gra.io.cloud.ovh.net",
          "https://*.s3.gra.io.cloud.ovh.net"
        ],
        "font-src": "'self'",
        "object-src": "'none'",
        "frame-src": "'none'"
      },
      "assetProtocol": {
        "enable": false,
        "scope": []
      },
      "capabilities": ["default"],
      "dangerousDisableAssetCspModification": false,
      "freezePrototype": false,
      "headers": {
        "X-Content-Type-Options": "nosniff"
      },
      "pattern": {
        "use": "brownfield"
      }
    },
    "withGlobalTauri": false
  },
  "bundle": {
    "createUpdaterArtifacts": true,
    "active": true,
    "category": "Business",
    "copyright": "Alyvo",
    "longDescription": "Alyvo Edu is a desktop application for education.",
    "shortDescription": "Alyvo Edu desktop application.",
    "license": "Proprietary",
    "licenseFile": "./legal/LICENSE.txt",
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "publisher": "Alyvo",
    "resources": [],
    "externalBin": ["binaries/outlook-creator", "binaries/broward-enrollment", "binaries/broward-student-id"],
    "fileAssociations": [],
    "homepage": "https://alyvo.fr",
    "useLocalToolsDir": false,
    "linux": {
      "appimage": {
        "bundleMediaFramework": true,
        "files": {}
      },
      "deb": {
        "files": {}
      },
      "rpm": {
        "epoch": 0,
        "files": {},
        "release": "1"
      }
    },
    "macOS": {
      "minimumSystemVersion": "15.0",
      "files": {},
      "hardenedRuntime": true,
      "entitlements": null,
      "exceptionDomain": "staging.api.edu.alyvo.fr api.edu.alyvo.fr",
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": null,
      "dmg": {}
    },
    "windows": {
      "webviewInstallMode": {
        "silent": true,
        "type": "offlineInstaller"
      },
      "allowDowngrades": false,
      "nsis": null,
      "wix": null
    }
  },
  "plugins": {
    "fs": {
      "requireLiteralLeadingDot": false
    },
    "updater": {
      "windows": {
        "installMode": "passive"
      },
      "active": true,
      "endpoints": ["https://api.edu.alyvo.fr/software/updater/{{target}}/{{arch}}/{{current_version}}"],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE5NjU0QjdDQTI1Njk4MDYKUldRR21GYWlmRXRsR2Faekh4WGJSeVR4czJkTFZFSzI0enVtaGxxc2dNWm9yZG1nN0ZIU2Q3NXQK",
      "dangerousInsecureTransportProtocol": false
    }
  }
}
